class Solution {
    public void connect(Node root) {
        if (root == null) return;
        
        Queue<Node> queue = new LinkedList<>();
        queue.offer(root);
        
        while (!queue.isEmpty()) {
            int levelSize = queue.size();
            
            for (int i = 0; i < levelSize; i++) {
                Node curr = queue.poll();
                
                if (i < levelSize - 1) {
                    curr.nextRight = queue.peek();
                }
                
                if (curr.left != null) {
                    queue.offer(curr.left);
                }
                if (curr.right != null) {
                    queue.offer(curr.right);
                }
            }
        }
    }
}

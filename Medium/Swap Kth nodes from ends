class Solution {
    public Node swapKth(Node head, int k) {
        if (head == null || head.next == null) {
            return head;
        }
        
        int length = 0;
        Node current = head;
        while (current != null) {
            length++;
            current = current.next;
        }
        
        if (k > length) {
            return head;
        }
        
        if (k == length - k + 1) {
            return head;
        }
        
        Node firstPrev = null;
        Node first = head;
        for (int i = 1; i < k; i++) {
            firstPrev = first;
            first = first.next;
        }
        
        Node secondPrev = null;
        Node second = head;
        for (int i = 1; i < length - k + 1; i++) {
            secondPrev = second;
            second = second.next;
        }
        
        if (firstPrev != null) {
            firstPrev.next = second;
        } else {
            head = second;
        }
        
        if (secondPrev != null) {
            secondPrev.next = first;
        } else {
            head = first;
        }
        
        Node temp = first.next;
        first.next = second.next;
        second.next = temp;
        
        return head;
    }
}

class Solution {
    public int countSquares(int N, int M, int[][] mat) {
        int total = 0;
        
        for (int i = 0; i < N; i++) {
            for (int j = 0; j < M; j++) {
                if (mat[i][j] == 0) continue;
                
                if (i > 0 && j > 0) {
                    mat[i][j] = 1 + Math.min(mat[i-1][j], Math.min(mat[i][j-1], mat[i-1][j-1]));
                }
                total += mat[i][j];
            }
        }
        return total;
    }
}

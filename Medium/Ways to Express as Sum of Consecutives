class Solution {
    public int getCount(int n) {
        int count = 0;
        
        int maxK = (int)((Math.sqrt(8L * n + 1) - 1) / 2);
        
        for (int k = 2; k <= maxK; k++) {
            long numerator = n - (long)k * (k - 1) / 2;
            if (numerator > 0 && numerator % k == 0) {
                count++;
            }
        }
        return count;
    }
}

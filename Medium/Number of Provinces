class Solution {
    static int numProvinces(ArrayList<ArrayList<Integer>> adj, int V) {
        boolean[] visited = new boolean[V];
        int provinces = 0;
        
        for (int i = 0; i < V; i++) {
            if (!visited[i]) {
                provinces++;
                dfs(adj, i, visited, V);
            }
        }
        
        return provinces;
    }
    
    static void dfs(ArrayList<ArrayList<Integer>> adj, int node, boolean[] visited, int V) {
        visited[node] = true;
        
        for (int neighbor = 0; neighbor < V; neighbor++) {
            if (adj.get(node).get(neighbor) == 1 && !visited[neighbor]) {
                dfs(adj, neighbor, visited, V);
            }
        }
    }
}

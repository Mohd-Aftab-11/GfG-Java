class Tree {
    boolean IsFoldable(Node node) {
        if (node == null) {
            return true;
        }
        return isMirror(node.left, node.right);
    }
    boolean isMirror(Node left, Node right) {
        if (left == null && right == null) {
            return true;
        }
        if (left == null || right == null) {
            return false;
        }
        return isMirror(left.left, right.right) && isMirror(left.right, right.left);
    }
}

class Solution {
    public int celebrity(int mat[][]) {
        int n = mat.length;
        
        int left = 0;
        int right = n - 1;
        
        while (left < right) {
            if (mat[left][right] == 1) {
                left++;
            } else {
                right--;
            }
        }
        
        int candidate = left;
        
        for (int i = 0; i < n; i++) {
            if (i != candidate) {
                if (mat[candidate][i] == 1 || mat[i][candidate] == 0) {
                    return -1;
                }
            }
        }
        
        return candidate;
    }
}

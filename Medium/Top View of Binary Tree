class Solution {
    class QueueNode {
        Node node;
        int hd;
        
        QueueNode(Node node, int hd) {
            this.node = node;
            this.hd = hd;
        }
    }
    
    public ArrayList<Integer> topView(Node root) {
        ArrayList<Integer> result = new ArrayList<>();
        
        if (root == null) {
            return result;
        }
        
        TreeMap<Integer, Integer> topViewMap = new TreeMap<>();
        
        Queue<QueueNode> queue = new LinkedList<>();
        queue.add(new QueueNode(root, 0));
        
        while (!queue.isEmpty()) {
            QueueNode current = queue.poll();
            Node node = current.node;
            int hd = current.hd;
            
            if (!topViewMap.containsKey(hd)) {
                topViewMap.put(hd, node.data);
            }
            
            if (node.left != null) {
                queue.add(new QueueNode(node.left, hd - 1));
            }
            
            if (node.right != null) {
                queue.add(new QueueNode(node.right, hd + 1));
            }
        }
        
        for (int value : topViewMap.values()) {
            result.add(value);
        }
        
        return result;
    }
}

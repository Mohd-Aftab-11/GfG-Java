class Solution {
    int findMaxSum(int arr[], int n) {
        if (n == 0) return 0;
        if (n == 1) return arr[0];
        
        int prevPrev = arr[0];
        int prev = Math.max(arr[0], arr[1]);
        
        for (int i = 2; i < n; i++) {
            int include = prevPrev + arr[i];
            int exclude = prev;
            int current = Math.max(include, exclude);
            prevPrev = prev;
            prev = current;
        }
        return prev;
    }
}

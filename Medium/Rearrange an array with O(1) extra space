class Solution {
    public void arrange(long[] arr) {
        int n = arr.length;
        
        for (int i = 0; i < n; i++) {
            long oldVal = arr[i] % n;
            long newVal = arr[(int) oldVal] % n;
            arr[i] = oldVal + n * newVal;
        }
        for (int i = 0; i < n; i++) {
            arr[i] = arr[i] / n;
        }
    }
}

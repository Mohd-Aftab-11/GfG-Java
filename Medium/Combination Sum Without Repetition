import java.util.*;

class Solution {
    public ArrayList<ArrayList<Integer>> uniqueCombinations(int[] arr, int target) {
        ArrayList<ArrayList<Integer>> result = new ArrayList<>();
        Arrays.sort(arr);
        
        backtrack(result, new ArrayList<>(), arr, target, 0);
        return result;
    }
    
    private void backtrack(ArrayList<ArrayList<Integer>> result, ArrayList<Integer> current, int[] arr, int remaining, int start) {
        
        if (remaining == 0) {
            result.add(new ArrayList<>(current));
            return;
        }
        
        for (int i = start; i < arr.length; i++) {
            if (i > start && arr[i] == arr[i - 1]) {
                continue;
            }
            
            if (arr[i] > remaining) {
                break;
            }
            
            current.add(arr[i]);
            
            backtrack(result, current, arr, remaining - arr[i], i + 1);
            
            current.remove(current.size() - 1);
        }
    }
}

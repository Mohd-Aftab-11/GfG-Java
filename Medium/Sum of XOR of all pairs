class Solution {
    public long sumXOR(int[] arr) {
        long total = 0;
        int n = arr.length;
        
        for (int bit = 0; bit < 20; bit++) {
            long count1 = 0;
            for (int num : arr) {
                if ((num & (1 << bit)) != 0) {
                    count1++;
                }
            }
            long count0 = n - count1;
            total += count0 * count1 * (1L << bit);
        }
        return total;
    }
}

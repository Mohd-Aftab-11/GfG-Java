class Solution {
    public boolean validateOp(int[] a, int[] b) {
        java.util.Stack<Integer> stack = new java.util.Stack<>();
        
        int j = 0;
        
        for (int i = 0; i < a.length; i++) {
            stack.push(a[i]);
            
            while (!stack.isEmpty() && stack.peek() == b[j]) {
                stack.pop();
                j++;
            }
        }
        
        return j == b.length;
    }
}

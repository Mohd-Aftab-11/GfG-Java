class Solution {
    public ArrayList<ArrayList<Integer>> combinationSum(int n, int k) {
        ArrayList<ArrayList<Integer>> result = new ArrayList<>();
        ArrayList<Integer> current = new ArrayList<>();
        
        backtrack(n, k, 1, current, result);
        
        return result;
    }
    
    private void backtrack(int remainingSum, int remainingNumbers, int start, 
                          ArrayList<Integer> current, ArrayList<ArrayList<Integer>> result) {
        if (remainingNumbers == 0 && remainingSum == 0) {
            result.add(new ArrayList<>(current));
            return;
        }
        
        if (remainingNumbers == 0 || remainingSum < 0) {
            return;
        }
        
        for (int i = start; i <= 9; i++) {
            if (i > remainingSum) {
                break;
            }
            
            current.add(i);
            
            backtrack(remainingSum - i, remainingNumbers - 1, i + 1, current, result);
            
            current.remove(current.size() - 1);
        }
    }
}

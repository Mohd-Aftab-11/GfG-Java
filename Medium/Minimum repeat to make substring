class Solution {
    public int minRepeats(String s1, String s2) {
        int m = s1.length();
        int n = s2.length();
        
        int minRepeats = (n + m - 1) / m;
        
        StringBuilder sb = new StringBuilder();
        for (int i = 0; i < minRepeats; i++) {
            sb.append(s1);
        }
        
        String repeated = sb.toString();
        if (repeated.contains(s2)) {
            return minRepeats;
        }
        
        repeated += s1;
        if (repeated.contains(s2)) {
            return minRepeats + 1;
        }
        return -1;
    }
}

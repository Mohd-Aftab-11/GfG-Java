class Solution {
    public int knapSack(int val[], int wt[], int capacity) {
        int[] dp = new int[capacity + 1];
        
        for (int i = 0; i < val.length; i++) {
            for (int w = wt[i]; w <= capacity; w++) {
                dp[w] = Math.max(dp[w], dp[w - wt[i]] + val[i]);
            }
        }
        return dp[capacity];
    }
}

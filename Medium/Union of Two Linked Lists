import java.util.*;

class Solution {
    public static Node makeUnion(Node head1, Node head2) {
        Set<Integer> set = new TreeSet<>();
        
        Node temp = head1;
        while (temp != null) {
            set.add(temp.data);
            temp = temp.next;
        }
        
        temp = head2;
        while (temp != null) {
            set.add(temp.data);
            temp = temp.next;
        }
        Node dummy = new Node(-1);
        Node current = dummy;
        for (int val : set) {
            current.next = new Node(val);
            current = current.next;
        }
        return dummy.next;
    }
}

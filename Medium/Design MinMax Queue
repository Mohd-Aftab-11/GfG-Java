import java.util.*;

class SpecialQueue {
    private Queue<Integer> queue;
    private Deque<Integer> minDeque;
    private Deque<Integer> maxDeque;
    
    public SpecialQueue() {
        queue = new LinkedList<>();
        minDeque = new LinkedList<>();
        maxDeque = new LinkedList<>();
    }

    public void enqueue(int x) {
        queue.offer(x);
        
        while (!minDeque.isEmpty() && minDeque.peekLast() > x) {
            minDeque.pollLast();
        }
        minDeque.offerLast(x);
        
        while (!maxDeque.isEmpty() && maxDeque.peekLast() < x) {
            maxDeque.pollLast();
        }
        maxDeque.offerLast(x);
    }

    public void dequeue() {
        if (queue.isEmpty()) return;
        
        int removed = queue.poll();
        
        if (!minDeque.isEmpty() && minDeque.peekFirst() == removed) {
            minDeque.pollFirst();
        }
        
        if (!maxDeque.isEmpty() && maxDeque.peekFirst() == removed) {
            maxDeque.pollFirst();
        }
    }

    public int getFront() {
        return queue.peek();
    }

    public int getMin() {
        return minDeque.peekFirst();
    }

    public int getMax() {
        return maxDeque.peekFirst();
    }
}

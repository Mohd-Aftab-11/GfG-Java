class Solution {
    public static ArrayList<Integer> countBits(int n) {
        ArrayList<Integer> result = new ArrayList<>(n + 1);
        
        for (int i = 0; i <= n; i++) {
            result.add(0);
        }
        
        for (int i = 1; i <= n; i++) {
            if (i % 2 == 0) {
                result.set(i, result.get(i / 2));
            } else {
                result.set(i, result.get(i / 2) + 1);
            }
        }
        
        return result;
    }
}

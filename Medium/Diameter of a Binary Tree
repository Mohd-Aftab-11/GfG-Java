class Solution {
    private class Result {
        int height;
        int diameter;
        
        Result(int height, int diameter) {
            this.height = height;
            this.diameter = diameter;
        }
    }
    
    public int diameter(Node root) {
        Result result = calculateDiameter(root);
        return result.diameter;
    }
    
    private Result calculateDiameter(Node node) {
        if (node == null) {
            return new Result(0, 0);
        }
        
        Result left = calculateDiameter(node.left);
        Result right = calculateDiameter(node.right);
        
        int currentHeight = Math.max(left.height, right.height) + 1;
        
        int pathThroughRoot = left.height + right.height;
        
        int currentDiameter = Math.max(pathThroughRoot, 
                                      Math.max(left.diameter, right.diameter));
        
        return new Result(currentHeight, currentDiameter);
    }
}

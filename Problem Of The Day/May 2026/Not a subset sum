class Solution {
    public int findSmallest(int[] arr) {
        java.util.Arrays.sort(arr);
        
        int res = 1;
        
        for (int i = 0; i < arr.length; i++) {
            if (arr[i] <= res) {
                res += arr[i];
            } else {
                break;
            }
        }
        return res;
    }
}

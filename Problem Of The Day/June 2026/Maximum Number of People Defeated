class Solution {
    int maxPeopleDefeated(int p) {
        long low = 1;
        long high = (long)Math.pow(3 * p, 1.0/3.0) + 10;
        
        while (low <= high) {
            long mid = low + (high - low) / 2;
            long sum = mid * (mid + 1) * (2 * mid + 1) / 6;
            
            if (sum <= p) {
                low = mid + 1;
            } else {
                high = mid - 1;
            }
        }
        return (int)high;
    }
}

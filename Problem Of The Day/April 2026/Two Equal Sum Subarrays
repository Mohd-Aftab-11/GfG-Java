class Solution {
    public boolean canSplit(int arr[]) {
        long totalSum = 0;
        
        for (int num : arr) {
            totalSum += num;
        }
        if (totalSum % 2 != 0) {
            return false;
        }
        
        long leftSum = 0;
        long target = totalSum / 2;
        
        for (int i = 0; i < arr.length - 1; i++) {
            leftSum += arr[i];
            
            if (leftSum == target) {
                return true;
            }
            
            if (leftSum > target) {
                return false;
            }
        }
        return false;
    }
}

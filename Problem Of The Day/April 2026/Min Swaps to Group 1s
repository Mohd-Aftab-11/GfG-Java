class Solution {
    public int minSwaps(int[] arr) {
        int n = arr.length;
        
        int totalOnes = 0;
        for (int num : arr) {
            if (num == 1) totalOnes++;
        }
        
        if (totalOnes == 0) return -1;
        
        int zerosInWindow = 0;
        for (int i = 0; i < totalOnes; i++) {
            if (arr[i] == 0) zerosInWindow++;
        }
        
        int minSwaps = zerosInWindow;
        
        for (int i = totalOnes; i < n; i++) {
            if (arr[i - totalOnes] == 0) zerosInWindow--;
            if (arr[i] == 0) zerosInWindow++;
            
            minSwaps = Math.min(minSwaps, zerosInWindow);
        }
        return minSwaps;
    }
}

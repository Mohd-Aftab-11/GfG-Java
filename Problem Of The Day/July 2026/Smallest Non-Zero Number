class Solution {
    public int find(int[] arr) {
        double maxReq = 0;
        double weightedSum = 0;
        double pow2 = 1;
        
        for (int i = 0; i < arr.length; i++) {
            long requirement = arr[i];
        }
        long ans = 0;
        for (int i = arr.length - 1; i >= 0; i--) {
            ans = (ans + arr[i] + 1) / 2;
        }
        return (int)ans;
    }
}

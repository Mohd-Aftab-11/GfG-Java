class Solution {
    public int kokoEat(int[] arr, int k) {
        int left = 1;
        int right = 0;
        
        for (int pile : arr) {
            right = Math.max(right, pile);
        }
        
        while (left < right) {
            int mid = left + (right - left) / 2;
            
            if (canEatAll(arr, k, mid)) {
                right = mid;
            } else {
                left = mid + 1;
            }
        }
        
        return left;
    }
    
    private boolean canEatAll(int[] arr, int k, int speed) {
        int hoursNeeded = 0;
        for (int pile : arr) {
            hoursNeeded += (pile + speed - 1) / speed;
            if (hoursNeeded > k) {
                return false;
            }
        }
        return hoursNeeded <= k;
    }
}

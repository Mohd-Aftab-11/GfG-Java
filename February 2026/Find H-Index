class Solution {
    public int hIndex(int[] citations) {
        Arrays.sort(citations);
        int n = citations.length;
        int hIndex = 0;
        
        for (int i = n - 1; i >= 0; i--) {
            int papersWithAtLeastThisMany = n - i;
            
            if (citations[i] >= papersWithAtLeastThisMany) {
                hIndex = papersWithAtLeastThisMany;
            } else {
                break;
            }
        }
        
        return hIndex;
    }
}

class Solution {
    static String studentRecord(String[][] vec, int N) {
        int maxAverage = -1;
        ArrayList<String> maxStudents = new ArrayList<>();
        
        for (int i = 0; i < N; i++) {
            String[] record = vec[i];
            
            String name = record[0];
            
            int sum = 0;
            for (int j = 1; j <= 3; j++) {
                sum += Integer.parseInt(record[j]);
            }
            
            int average = sum / 3;
            
            if (average > maxAverage) {
                maxAverage = average;
                maxStudents.clear();
                maxStudents.add(name);
            } else if (average == maxAverage) {
                maxStudents.add(name);
            }
        }
        
        StringBuilder result = new StringBuilder();
        for (String name : maxStudents) {
            result.append(name).append(" ");
        }
        result.append(maxAverage);
        
        return result.toString();
    }
}

class Solution {
    int isDivisible(int N) {
        int originalN = N;
        
        int digitSum = 0;
        while (N > 0) {
            digitSum += N % 10;
            N = N / 10;
        }
        
        if (originalN % digitSum == 0) {
            return 1;
        } else {
            return 0;
        }
    }
}

import java.util.ArrayList;
import java.util.List;

class myQueue {
    private List<Integer> queue;
    
    public myQueue() {
        queue = new ArrayList<>();
    }

    public void enqueue(int x) {
        queue.add(x);
    }

    public void dequeue() {
        if (!queue.isEmpty()) {
            queue.remove(0);
        }
    }

    public int getFront() {
        if (queue.isEmpty()) {
            return -1;
        }
        return queue.get(0);
    }

    public int getRear() {
        if (queue.isEmpty()) {
            return -1;
        }
        return queue.get(queue.size() - 1);
    }

    public boolean isEmpty() {
        return queue.isEmpty();
    }

    public int size() {
        return queue.size();
    }
}

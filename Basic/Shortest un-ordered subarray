class Solution {
    public int shortestUnorderedSubarray(int arr[]) {
        int n = arr.length;
        
        for (int i = 0; i < n - 2; i++) {
            int a = arr[i];
            int b = arr[i + 1];
            int c = arr[i + 2];
            
            if (!(a < b && b < c) && !(a > b && b > c)) {
                return 3;
            }
        }
        
        return 0;
    }
}

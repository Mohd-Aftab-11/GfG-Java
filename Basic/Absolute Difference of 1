class Solution {
    public ArrayList<Integer> getDigitDiff1AndLessK(int[] arr, int k) {
        ArrayList<Integer> result = new ArrayList<>();
        
        for (int num : arr) {
            if (num < k && num >= 10) {
                if (hasAdjacentDigitDiffOne(num)) {
                    result.add(num);
                }
            }
        }
        
        return result;
    }
    
    private boolean hasAdjacentDigitDiffOne(int num) {
        String numStr = String.valueOf(num);
        
        for (int i = 0; i < numStr.length() - 1; i++) {
            int digit1 = numStr.charAt(i) - '0';
            int digit2 = numStr.charAt(i + 1) - '0';
            
            if (Math.abs(digit1 - digit2) != 1) {
                return false;
            }
        }
        
        return true;
    }
}

class Solution {
    public long findMultiplication(int[] arr1, int[] arr2) {
        int max1 = Integer.MIN_VALUE;
        for (int num : arr1) {
            if (num > max1) {
                max1 = num;
            }
        }
        
        int min2 = Integer.MAX_VALUE;
        for (int num : arr2) {
            if (num < min2) {
                min2 = num;
            }
        }
        
        return (long) max1 * min2;
    }
}

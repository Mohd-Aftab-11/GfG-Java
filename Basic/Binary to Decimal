class Solution {
    public int binaryToDecimal(String b) {
        int decimal = 0;
        int power = 0;
        
        for (int i = b.length() - 1; i >= 0; i--) {
            char bit = b.charAt(i);
            if (bit == '1') {
                decimal += Math.pow(2, power);
            }
            power++;
        }
        
        return decimal;
    }
}

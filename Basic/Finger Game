class Solution {
    static int fingerCount(int N) {
        int remainder = N % 8;
        
        if (remainder == 1) {
            return 1;
        } else if (remainder == 2 || remainder == 0) {
            return 2;
        } else if (remainder == 3 || remainder == 7) {
            return 3;
        } else if (remainder == 4 || remainder == 6) {
            return 4;
        } else if (remainder == 5) {
            return 5;
        }
        
        return -1;
    }
}

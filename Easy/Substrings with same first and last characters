class Solution {
    public int countSubstring(String s) {
        int n = s.length();
        int[] freq = new int[26];
        
        for (int i = 0; i < n; i++) {
            freq[s.charAt(i) - 'a']++;
        }
        
        int count = 0;
        for (int i = 0; i < 26; i++) {
            if (freq[i] > 0) {
                count += (freq[i] * (freq[i] + 1)) / 2;
            }
        }
        return count;
    }
}

class Solution {
    public Node insertPos(Node head, int pos, int val) {
        Node newNode = new Node(val);
        
        if (pos == 1) {
            newNode.next = head;
            return newNode;
        }
        Node current = head;
        for (int i = 1; i < pos - 1 && current != null; i++) {
            current = current.next;
        }
        if (current == null) {
            return head;
        }
        newNode.next = current.next;
        current.next = newNode;
        
        return head;
    }
}

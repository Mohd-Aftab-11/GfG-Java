class Solution {
    int minToggle(int[] arr) {
        int n = arr.length;
        
        int totalOnes = 0;
        for (int num : arr) {
            if (num == 1) totalOnes++;
        }
        
        int onesBefore = 0;
        int minToggles = n;
        
        for (int i = 0; i <= n; i++) {
            int zerosAfter = (n - i) - (totalOnes - onesBefore);
            int toggles = onesBefore + zerosAfter;
            minToggles = Math.min(minToggles, toggles);
            
            if (i < n && arr[i] == 1) {
                onesBefore++;
            }
        }
        return minToggles;
    }
}

class Solution {
    int thirdLargest(int arr[]) {
        int n = arr.length;
        if (n < 3) return -1;
        
        int first = arr[0], second = Integer.MIN_VALUE, third = Integer.MIN_VALUE;
        
        for (int i = 1; i < n; i++) {
            int num = arr[i];
            if (num > first) {
                third = second;
                second = first;
                first = num;
            } else if (num > second) {
                third = second;
                second = num;
            } else if (num > third) {
                third = num;
            }
        }
        
        return third;
    }
}

class Solution {
    int minSubsets(int arr[]) {
        if (arr == null || arr.length == 0) {
            return 0;
        }
        if (arr.length == 1) {
            return 1;
        }
        Arrays.sort(arr);
        
        int subsets = 1;
        
        for (int i = 1; i < arr.length; i++) {
            if (arr[i] != arr[i - 1] + 1) {
                subsets++;
            }
        }
        return subsets;
    }
}

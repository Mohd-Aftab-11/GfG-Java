import java.util.*;

class Solution {
    public ArrayList<Integer> prefSum(int[] arr) {
        ArrayList<Integer> prefixSum = new ArrayList<>();
        
        if (arr == null || arr.length == 0) {
            return prefixSum;
        }
        
        int runningSum = 0;
        for (int i = 0; i < arr.length; i++) {
            runningSum += arr[i];
            prefixSum.add(runningSum);
        }
        
        return prefixSum;
    }
}

import java.util.List;

class Solution {
    public int calculateMaxSumLength(List<Integer> arr, int k) {
        int sum = 0;
        int currentLength = 0;
        boolean containsK = false;
        
        for (int i = 0; i < arr.size(); i++) {
            int num = arr.get(i);
            
            if (num > k) {
                if (containsK) {
                    sum += currentLength;
                }
                currentLength = 0;
                containsK = false;
            } else {
                currentLength++;
                if (num == k) {
                    containsK = true;
                }
            }
        }
        if (containsK) {
            sum += currentLength;
        }
        return sum;
    }
}

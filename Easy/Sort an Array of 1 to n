class Solution {
    int[] sortArray(int arr[]) {
        int n = arr.length;
        
        for (int i = 0; i < n; i++) {
            while (arr[i] != i + 1) {
                int temp = arr[arr[i] - 1];
                arr[arr[i] - 1] = arr[i];
                arr[i] = temp;
            }
        }
        return arr;
    }
}

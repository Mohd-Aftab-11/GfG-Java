class Solution {
    static Long nthFaithfulNum(int N) {
        long result = 0;
        long power = 1;
        
        while (N > 0) {
            if ((N & 1) == 1) {
                result += power;
            }
            power *= 7;
            
            N >>= 1;
        }
        return result;
    }
}

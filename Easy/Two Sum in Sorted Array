class Solution {
    public ArrayList<Integer> twoSum(int[] arr, int target) {
        int left = 0;
        int right = arr.length - 1;
        
        while (left < right) {
            int sum = arr[left] + arr[right];
            
            if (sum == target) {
                ArrayList<Integer> result = new ArrayList<>();
                result.add(left + 1);
                result.add(right + 1);
                return result;
            } else if (sum < target) {
                left++;
            } else {
                right--;
            }
        }
        
        ArrayList<Integer> result = new ArrayList<>();
        result.add(-1);
        result.add(-1);
        return result;
    }
}

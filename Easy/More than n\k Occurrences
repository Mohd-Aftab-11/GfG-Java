class Solution {
    public int countOccurence(int[] arr, int k) {
        int n = arr.length;
        int threshold = n / k;
        int count = 0;
        
        HashMap<Integer, Integer> frequencyMap = new HashMap<>();
        
        for (int num : arr) {
            frequencyMap.put(num, frequencyMap.getOrDefault(num, 0) + 1);
        }
        
        for (int freq : frequencyMap.values()) {
            if (freq > threshold) {
                count++;
            }
        }
        
        return count;
    }
}

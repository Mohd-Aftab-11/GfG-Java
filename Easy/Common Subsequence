class Sol {
    Boolean commonSubseq(String a, String b) {
        boolean[] present = new boolean[256];
        
        for (int i = 0; i < a.length(); i++) {
            present[a.charAt(i)] = true;
        }
        for (int i = 0; i < b.length(); i++) {
            if (present[b.charAt(i)]) {
                return true;
            }
        }
        return false;
    }
}

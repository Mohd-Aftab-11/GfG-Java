import java.util.*;

class Solution {
    static ArrayList<Integer> nextGreatest(int arr[]) {
        int n = arr.length;
        ArrayList<Integer> result = new ArrayList<>();
        
        if (n == 0) return result;
        
        result.add(-1);
        
        int maxFromRight = arr[n - 1];
        
        for (int i = n - 2; i >= 0; i--) {
            result.add(maxFromRight);
            
            if (arr[i] > maxFromRight) {
                maxFromRight = arr[i];
            }
        }
        
        Collections.reverse(result);
        
        return result;
    }
}

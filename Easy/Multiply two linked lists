class Solution {
    public long multiplyTwoLists(Node first, Node second) {
        long MOD = 1000000007L;
        long num1 = 0, num2 = 0;
        
        Node temp = first;
        while (temp != null) {
            num1 = (num1 * 10 + temp.data) % MOD;
            temp = temp.next;
        }
        temp = second;
        while (temp != null) {
            num2 = (num2 * 10 + temp.data) % MOD;
            temp = temp.next;
        }
        return (num1 * num2) % MOD;
    }
}

class Solution {
    static void solve(Stack<Integer> st, int count, int n) {
        if (count == n / 2) {
            st.pop();
            return;
        }
        int top = st.pop();
        solve(st, count + 1, n);
        st.push(top);
    }
    
    static Stack<Integer> deleteMid(int n, Stack<Integer> st) {
        solve(st, 0, n);
        return st;
    }
}

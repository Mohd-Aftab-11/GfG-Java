import java.util.*;

class Solution {
    public int sumDiffPairs(int[] arr, int k) {
        int n = arr.length;
        if (n < 2) return 0;
        
        Arrays.sort(arr);
        int[] dp = new int[n + 1];
        
        for (int i = 1; i < n; i++) {
            dp[i + 1] = dp[i];
            if (arr[i] - arr[i - 1] < k) {
                dp[i + 1] = Math.max(dp[i + 1], dp[i - 1] + arr[i - 1] + arr[i]);
            }
        }
        return dp[n];
    }
}

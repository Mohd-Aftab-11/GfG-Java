class Solution {
    public boolean areDisjoint(int[] a, int[] b) {
        HashSet<Integer> set = new HashSet<>();
        
        for (int num : a) {
            set.add(num);
        }
        
        for (int num : b) {
            if (set.contains(num)) {
                return false;
            }
        }
        return true;
    }
}

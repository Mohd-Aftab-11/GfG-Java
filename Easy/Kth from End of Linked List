class Solution {
    int getKthFromLast(Node head, int k) {
        if (head == null) return -1;
        
        Node fast = head;
        Node slow = head;
        
        for (int i = 0; i < k; i++) {
            if (fast == null) {
                return -1;
            }
            fast = fast.next;
        }
        while (fast != null) {
            slow = slow.next;
            fast = fast.next;
        }
        return slow.data;
    }
}

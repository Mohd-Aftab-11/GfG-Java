class Solution {
    public int lcm(int a, int b) {
        int gcd = findGCD(a, b);
        
        long result = ((long) a * b) / gcd;
        
        return (int) result;
    }
    
    private int findGCD(int a, int b) {
        while (b != 0) {
            int temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }
}

class Solution {
    public int countIncreasing(int[] arr) {
        if (arr.length < 2) return 0;
        
        int totalCount = 0;
        int currentLength = 1;
        
        for (int i = 1; i < arr.length; i++) {
            if (arr[i] > arr[i-1]) {
                currentLength++;
            } else {
                if (currentLength >= 2) {
                    totalCount += currentLength * (currentLength - 1) / 2;
                }
                currentLength = 1;
            }
        }
        
        if (currentLength >= 2) {
            totalCount += currentLength * (currentLength - 1) / 2;
        }
        return totalCount;
    }
}

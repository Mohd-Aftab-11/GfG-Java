class Solution {
    public boolean search(Node root, int key) {
        Node current = root;
        
        while (current != null) {
            if (current.data == key) {
                return true;
            } else if (key < current.data) {
                current = current.left;
            } else {
                current = current.right;
            }
        }
        
        return false;
    }
}
